# MongoDB
NEXT_PUBLIC_MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/dotdev

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_CLOUDINARY_API_KEY=your_api_key
NEXT_PUBLIC_CLOUDINARY_API_SECRET=your_api_secret

# Admin Auth (magic link)
ADMIN_EMAILS=admin@reva.edu.in,president@dotdev.reva.edu.in
JWT_SECRET=generate_a_random_32char_string_here
SESSION_SECRET=generate_another_random_32char_string_here
NEXT_PUBLIC_DOMAIN=http://localhost:3000

# Nodemailer (Gmail with App Password)
MAIL_SMTP=smtp.gmail.com
MAIL_SMTP_PORT=465
MAIL_USER=your.gmail@gmail.com
MAIL_PASS=your_gmail_app_password

# Upstash Redis (for token invalidation)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token
